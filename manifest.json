{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "2.0.0",
  "default_locale": "en",
  "description": "__MSG_ext_description__",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "alarms",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.reddit.com/*",
        "*://*.linkedin.com/*",
        "*://*.tiktok.com/*"
      ],
      "css": [
        "css/facebook.css",
        "css/youtube.css",
        "css/instagram.css",
        "css/twitter.css",
        "css/reddit.css",
        "css/linkedin.css",
        "css/tiktok.css"
      ],
      "js": ["site-config.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "incognito": "spanning",
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
